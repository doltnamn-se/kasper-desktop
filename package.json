{
  "name": "kasper-desktop",
  "productName": "Kasper",
  "version": "2.1.18",
  "description": "Kasper Desktop App",
  "author": "Kasper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "publish:win": "electron-builder --win --publish always",
    "publish:mac": "electron-builder --mac --publish always",
    "release": "standard-version && git push --follow-tags origin main"
  },
  "build": {
    "appId": "com.kasper.desktop",
    "productName": "Kasper",
    "publish": [
      {
        "provider": "github",
        "owner": "doltnamn-se",
        "repo": "kasper-desktop",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "Kasper.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kasper",
      "license": "assets/license.txt",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "installerSidebar": "assets/installerSidebar.bmp",
      "installerHeader": "assets/installerHeader.bmp",
      "artifactName": "Kasper.exe"
    },
    "mac": {
  "target": ["dmg", "zip"],
  "icon": "assets/icon.icns",
  "hardenedRuntime": true,
  "gatekeeperAssess": false
},

"dmg": {
  "artifactName": "Kasper.dmg"
}
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "standard-version": "^9.5.0"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  }
}
